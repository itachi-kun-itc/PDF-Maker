{
  "expo": {
    "name": "PDFスキャン-結合",
    "slug": "PDFScannerApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pdfscannerapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "icon": "./assets/images/icon.png",
      "adaptiveIcon": {
        "backgroundColor": "#006CFF",
        "foregroundImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "display": "standalone",
      "themeColor": "#06152A",
      "backgroundColor": "#06152A",
      "name": "PDFスキャン-結合",
      "shortName": "PDFスキャン",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@config-plugins/react-native-blob-util",
      "@config-plugins/react-native-pdf",
      [
        "expo-image-picker",
        {
          "photosPermission": "このアプリはスキャン画像を取り込むために写真ライブラリへアクセスします。",
          "cameraPermission": "このアプリはスキャンや撮影のためにカメラへアクセスします。"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "react-native-document-scanner-plugin",
        {
          "cameraPermission": "このアプリは書類を高精度にスキャンするためにカメラへアクセスします。"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3e9b9dbe-2427-4909-91de-f14578c99530"
      }
    }
  }
}
